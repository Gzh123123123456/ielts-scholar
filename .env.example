# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Local-personal Provider Router v1. Vite exposes VITE_* values to browser code,
# so these are for a personal prototype only, not production key management.
VITE_AI_PROVIDER=auto
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"
VITE_GEMINI_MODEL=gemini-2.5-flash
VITE_GEMINI_RPM_LIMIT=5
VITE_GEMINI_TPM_LIMIT=250000
VITE_GEMINI_RPD_LIMIT=20
VITE_GEMINI_RPD_RESERVE=3
VITE_DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"
VITE_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
VITE_DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
VITE_DEEPSEEK_PRO_MODEL=deepseek-v4-pro
VITE_DEEPSEEK_PRO_DISCOUNT_END_UTC=2026-05-31T15:59:00Z
VITE_DEEPSEEK_ALLOW_PRO_AFTER_DISCOUNT=false

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
